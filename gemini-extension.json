{
  "name": "sql-server-dynamic-suite",
  "version": "1.0.0",
  "description": "Suite completa SQL Server (Query, List, Describe, Search) con credenziali dinamiche.",
  "mcpServers": {
    "sql-server-dynamic": {
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${extensionPath}/gemini.dynamic.mcp.csproj",
        "--configuration",
        "Release",
        "--"
      ],
      "env": {
        "DOTNET_SYSTEM_GLOBALIZATION_INVARIANT": "1"
      }
    }
  }
}
